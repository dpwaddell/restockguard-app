{% if product.selected_or_first_available_variant.available == false %}
  <div id="restockguard-container"></div>

  <script>
    window.restockguardConfig = {
      shopDomain: {{ shop.permanent_domain | json }},
      appUrl: {{ block.settings.app_url | json }},
      productId: {{ product.id | json }},
      variantId: {{ product.selected_or_first_available_variant.id | json }},
      buttonText: {{ block.settings.button_text | json }},
      successText: {{ block.settings.success_text | json }},
      styling: {
        buttonBg: {{ block.settings.button_bg | json }},
        buttonText: {{ block.settings.button_text_color | json }},
        borderRadius: {{ block.settings.border_radius | json }},
        fontSize: "16px"
      }
    };
  </script>

  <script src="{{ 'restockguard.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "RestockGuard",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "info": "Your RestockGuard deployment URL, e.g. https://your-tunnel.example.com"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Notify Button Text",
      "default": "Notify me when back in stock"
    },
    {
      "type": "text",
      "id": "success_text",
      "label": "Success Message",
      "default": "Thanks! We'll email you when it's back."
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 6,
      "unit": "px"
    }
  ]
}
{% endschema %}
