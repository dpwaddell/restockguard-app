# Shopify app credentials (from your Partner Dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_APP_URL=https://your-tunnel-domain.example.com
SCOPES=read_products,read_inventory,read_orders

# PostgreSQL (used by docker-compose for the db service and DATABASE_URL construction)
POSTGRES_DB=restock
POSTGRES_USER=restock
POSTGRES_PASSWORD=change_me_in_production

# Full connection strings (docker-compose overrides these for containerised services)
DATABASE_URL=postgresql://restock:change_me_in_production@localhost:5432/restock
REDIS_URL=redis://redis:6379

# Resend (transactional email)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM_NAME=RestockGuard
EMAIL_FROM_ADDRESS=alerts@your-domain.com

# App runtime (container listens on 3000 internally; host port is 3001 via docker-compose)
NODE_ENV=production
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_64_char_hex_string
